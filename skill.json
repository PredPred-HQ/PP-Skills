{
  "name": "predp-red-skill",
  "version": "1.0.0",
  "description": "AI Skill for trading predp.red prediction market with x402 payment",
  "author": "Your Team",
  "license": "MIT",
  "keywords": [
    "xlayer",
    "prediction-market",
    "x402",
    "onchainos",
    "openclaw",
    "ai-skill"
  ],
  "categories": [
    "defi",
    "payment",
    "trading"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@okx/onchainos-sdk": "^1.0.0",
    "ethers": "^6.11.0",
    "dotenv": "^16.4.1",
    "axios": "^1.6.7",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/predp-red-skill"
  },
  "bugs": {
    "url": "https://github.com/your-org/predp-red-skill/issues"
  },
  "homepage": "https://github.com/your-org/predp-red-skill#readme",
  "skill": {
    "name": "PredP.red",
    "description": "Trade prediction markets with natural language using x402 payment",
    "version": "1.0.0",
    "commands": [
      {
        "pattern": "查看.*市场",
        "description": "View prediction markets",
        "handler": "handleViewMarket"
      },
      {
        "pattern": "买入.*市场",
        "description": "Buy market shares",
        "handler": "handleBuy"
      },
      {
        "pattern": "卖出.*市场",
        "description": "Sell market shares",
        "handler": "handleSell"
      },
      {
        "pattern": "持仓",
        "description": "View positions",
        "handler": "handleViewPositions"
      }
    ],
    "configuration": {
      "properties": {
        "okxApiKey": {
          "type": "string",
          "description": "OKX API Key"
        },
        "okxSecretKey": {
          "type": "string",
          "description": "OKX Secret Key"
        },
        "okxPassphrase": {
          "type": "string",
          "description": "OKX Passphrase"
        },
        "contractAddress": {
          "type": "string",
          "description": "predp.red contract address"
        }
      },
      "required": [
        "okxApiKey",
        "okxSecretKey",
        "okxPassphrase",
        "contractAddress"
      ]
    }
  }
}
