{
  "name": "predp-red-x402-payment",
  "version": "1.0.0",
  "title": "PredP.red x402 Payment",
  "description": "A PredP.red payment skill that supports x402 payment with USDT on X Layer",
  "author": "",
  "license": "MIT",
  "keywords": ["predp.red", "x402", "payment", "usdt", "xlayer"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "skill": {
    "category": "payment",
    "subcategory": "crypto",
    "supportedLanguages": ["zh", "en"],
    "requiresConfiguration": true,
    "configurationSchema": {
      "type": "object",
      "properties": {
        "apiKey": {
          "type": "string",
          "description": "PredP.red API key"
        },
        "secretKey": {
          "type": "string",
          "description": "PredP.red secret key"
        },
        "passphrase": {
          "type": "string",
          "description": "PredP.red passphrase"
        },
        "chainId": {
          "type": "number",
          "description": "Blockchain network chain ID (default: 196 for X Layer Mainnet)",
          "default": 196
        },
        "language": {
          "type": "string",
          "description": "Language for responses (zh or en)",
          "default": "zh"
        },
        "recipientAddress": {
          "type": "string",
          "description": "Recipient address for payments",
          "default": "0x779ded0c9e1022225f8e0630b35a9b54be713736"
        },
        "serviceUrl": {
          "type": "string",
          "description": "PredP.red service API endpoint",
          "default": "https://xlayer.predp.red"
        }
      },
      "required": ["apiKey", "secretKey", "passphrase"]
    },
    "features": [
      "Process PredP.red payment requests",
      "Support multiple payment methods",
      "Handle payment verification",
      "Multi-language support (Chinese/English)",
      "Service price display",
      "Balance inquiries"
    ],
    "methods": [
      {
        "name": "processPredPRedX402Skill",
        "description": "Main entry point for processing payment messages",
        "parameters": [
          {
            "name": "message",
            "type": "string",
            "description": "User's payment request message"
          },
          {
            "name": "options",
            "type": "object",
            "description": "Skill configuration options"
          }
        ],
        "returns": "Promise<string>"
      },
      {
        "name": "createPredPRedX402Skill",
        "description": "Creates and initializes a new skill instance",
        "parameters": [
          {
            "name": "options",
            "type": "object",
            "description": "Skill configuration options"
          }
        ],
        "returns": "X402Skill"
      }
    ],
    "dependencies": {
      "axios": "^1.6.0",
      "dotenv": "^16.3.1"
    }
  }
}
